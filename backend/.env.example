PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/myhosurproperty
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# SMTP Configuration - Recommended provider: Resend
# Docs: https://resend.com/docs/send-with-smtp
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxx
EMAIL_FROM=MyHosurProperty <onboarding@yourdomain.com>
SUPPORT_EMAIL=support@yourdomain.com

# Payment Gateway
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
